{
  "name": "office-to-md-mcp",
  "version": "1.0.0",
  "description": "MCP server to convert Office/PDF documents into images and Markdown",
  "main": "dist/server.js",
  "bin": {
    "office-to-md-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npm run build && node dist/server.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "exceljs": "^4.4.0",
    "mammoth": "^1.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
